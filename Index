<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>💖 Relationship Renewal 💖</title>

<!-- Google Font -->
<link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins:wght@300;500&display=swap" rel="stylesheet">

<style>
body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    text-align: center;
    background: linear-gradient(135deg, #fff0f5, #ffe4e1, #fff);
    color: #d63384;
    overflow-x: hidden;
}

h1 {
    font-family: 'Pacifico', cursive;
    font-size: 2.5rem;
}

.container {
    padding: 20px;
}

.grid {
    display: grid;
    gap: 5px;
    justify-content: center;
    margin: 20px auto;
}

.tile {
    width: 90px;
    height: 90px;
    background-size: cover;
    border-radius: 12px;
    cursor: pointer;
    transition: transform 0.2s;
}

.tile:hover {
    transform: scale(1.05);
}

button {
    padding: 10px 20px;
    border: none;
    background: #ff4d6d;
    color: white;
    border-radius: 20px;
    cursor: pointer;
    margin-top: 10px;
    font-size: 1rem;
}

.hidden { display: none; }

/* Floating hearts */
.heart {
    position: fixed;
    bottom: -10px;
    font-size: 20px;
    animation: floatUp 6s linear infinite;
}

@keyframes floatUp {
    0% { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(-100vh); opacity: 0; }
}
</style>
</head>
<body>

<div class="container">
    <h1>💖 Relationship Renewal 💖</h1>
    <p>Complete all stages to unlock something special 💌</p>

    <button onclick="startGame()">Start Game</button>

    <div id="game"></div>

    <div id="quiz" class="hidden">
        <h2>💕 Final Quiz 💕</h2>
        <div id="questionBox"></div>
    </div>
</div>

<!-- Background Music -->
<audio id="bgMusic" loop>
    <source src="music.mp3" type="audio/mpeg">
</audio>

<script>
// ================= CONFIG =================
const images = [
    "stage1.jpg",
    "stage2.jpg",
    "stage3.jpg"
];

const quizData = [
    {
        q: "Question 1: When did we first meet?",
        options: ["A", "B", "C", "D"],
        correct: 0
    },
    {
        q: "Question 2: Our favorite place?",
        options: ["A", "B", "C", "D"],
        correct: 1
    },
    {
        q: "Question 3: What do you love about me?",
        options: ["A", "B", "C", "D"],
        correct: 2
    },
    {
        q: "Question 4: Our best memory?",
        options: ["A", "B", "C", "D"],
        correct: 3
    },
    {
        q: "Question 5: Will you renew our love? 💖",
        options: ["Yes", "Of course", "Always", "Forever"],
        correct: 3
    }
];
// ==========================================

let stage = 0;
let size = 3;
let selected = null;
let currentQuestion = 0;

function startGame() {
    document.getElementById('bgMusic').play();
    stage = 0;
    loadStage();
}

function loadStage() {
    const game = document.getElementById('game');
    game.innerHTML = `<h2>Stage ${stage + 1}</h2>`;

    if (stage === 0) size = 3;
    if (stage === 1) size = 4;
    if (stage === 2) size = 5;

    const grid = document.createElement('div');
    grid.className = 'grid';
    grid.style.gridTemplateColumns = `repeat(${size}, 90px)`;

    let tiles = [...Array(size * size).keys()];
    tiles.sort(() => Math.random() - 0.5);

    tiles.forEach(index => {
        const tile = document.createElement('div');
        tile.className = 'tile';
        const x = index % size;
        const y = Math.floor(index / size);

        tile.style.backgroundImage = `url(${images[stage]})`;
        tile.style.backgroundSize = `${size * 90}px ${size * 90}px`;
        tile.style.backgroundPosition = `-${x * 90}px -${y * 90}px`;

        tile.onclick = () => selectTile(tile);
        grid.appendChild(tile);
    });

    game.appendChild(grid);
}

function selectTile(tile) {
    if (!selected) {
        selected = tile;
        tile.style.border = "3px solid red";
    } else {
        let temp = selected.style.backgroundPosition;
        selected.style.backgroundPosition = tile.style.backgroundPosition;
        tile.style.backgroundPosition = temp;
        selected.style.border = "none";
        selected = null;
        checkWin();
    }
}

function checkWin() {
    const tiles = document.querySelectorAll('.tile');
    let correct = true;

    tiles.forEach((tile, i) => {
        const x = i % size;
        const y = Math.floor(i / size);
        const pos = `-${x * 90}px -${y * 90}px`;
        if (tile.style.backgroundPosition !== pos) correct = false;
    });

    if (correct) {
        createHearts();
        setTimeout(() => {
            stage++;
            if (stage < 3) loadStage();
            else startQuiz();
        }, 1000);
    }
}

function createHearts() {
    for (let i = 0; i < 20; i++) {
        const heart = document.createElement('div');
        heart.className = 'heart';
        heart.innerHTML = '💖';
        heart.style.left = Math.random() * 100 + 'vw';
        heart.style.animationDuration = (3 + Math.random() * 3) + 's';
        document.body.appendChild(heart);

        setTimeout(() => heart.remove(), 6000);
    }
}

// QUIZ SYSTEM
function startQuiz() {
    document.getElementById('game').innerHTML = "";
    document.getElementById('quiz').classList.remove('hidden');
    currentQuestion = 0;
    showQuestion();
}

function showQuestion() {
    const qBox = document.getElementById('questionBox');
    const q = quizData[currentQuestion];

    qBox.innerHTML = `<h3>${q.q}</h3>`;

    q.options.forEach((opt, i) => {
        qBox.innerHTML += `<button onclick="nextQuestion(${i})">${opt}</button><br>`;
    });
}

function nextQuestion(selectedOption) {
    currentQuestion++;

    if (currentQuestion < quizData.length) {
        showQuestion();
    } else {
        document.getElementById('questionBox').innerHTML =
            "<h2>💖 Relationship Renewed Successfully 💖</h2>";
        createHearts();
    }
}
</script>

</body>
</html>
